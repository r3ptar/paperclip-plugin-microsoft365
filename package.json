{
  "name": "@paperclipai/plugin-microsoft-365",
  "version": "0.1.0",
  "description": "Microsoft 365 integration for Paperclip — syncs Planner tasks, searches SharePoint docs, and creates Outlook calendar events",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.318.0",
    "@paperclipai/shared": "^2026.318.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "microsoft-365",
    "planner",
    "sharepoint",
    "outlook",
    "graph-api"
  ],
  "license": "MIT"
}
